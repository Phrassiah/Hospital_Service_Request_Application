<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F8F9F9"> <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="vertical"
    android:layout_marginBottom="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ADMIN CONTROL PANEL"
        android:textColor="#2C3E50"
        android:textSize="24sp"
        android:textStyle="bold" />

    <View
        android:layout_width="100dp"
        android:layout_height="3dp"
        android:background="#2E86C1"
        android:layout_marginTop="5dp"/>
</LinearLayout>

    <EditText
        android:id="@+id/serviceInput"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Type Service Name Here..."
        android:background="@android:drawable/editbox_background"
        android:padding="12dp"
        android:drawablePadding="10dp"
        android:layout_marginBottom="15dp"/>

    <Button
        android:id="@+id/addBtn"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Add New Service"
        android:backgroundTint="#27AE60"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/removeServiceBtn"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Remove Selected Service"
        android:backgroundTint="#C0392B"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/viewRequestsBtn"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="View Patient Requests"
        android:backgroundTint="#2E86C1"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/viewUsersBtn"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Manage/Delete Users"
        android:backgroundTint="#34495E"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="15dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Data Preview:"
        android:textStyle="italic"
        android:textColor="#7F8C8D"/>

    <ListView
        android:id="@+id/listView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:divider="#D5D8DC"
        android:dividerHeight="1dp"
        android:elevation="2dp"
        android:layout_marginTop="5dp"/>

</LinearLayout>